---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	execute_step(execute_step)
	adaptive_review(adaptive_review)
	replan_tail(replan_tail)
	merge_plan(merge_plan)
	__end__([<p>__end__</p>]):::last
	__start__ --> execute_step;
	adaptive_review -.-> __end__;
	adaptive_review -.-> execute_step;
	adaptive_review -.-> replan_tail;
	execute_step --> adaptive_review;
	merge_plan -.-> __end__;
	merge_plan -.-> execute_step;
	replan_tail --> merge_plan;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
	
